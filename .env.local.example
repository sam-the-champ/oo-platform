# ================================================================
# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your Apps
# ================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ================================================================
# Admin Authentication
# Create a Firebase Auth user with email/password
# ================================================================
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# ================================================================
# GitHub API (for live repo data)
# Create a Personal Access Token at: github.com/settings/tokens
# Scopes needed: public_repo, read:user
# ================================================================
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_personal_access_token

# ================================================================
# Site Config
# ================================================================
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=Olalekan Ogundimu
