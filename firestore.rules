rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the request from a signed-in admin? ───────────────────
    function isAdmin() {
      return request.auth != null;
    }

    // ── Public read collections ───────────────────────────────────────────
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skills/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Config (profile, analytics) ──────────────────────────────────────
    match /config/{id} {
      allow read: if true;
      // analytics increment allowed for all (page view tracking)
      allow update: if id == 'analytics' || isAdmin();
      allow create, delete: if isAdmin();
    }

    // ── Write-only for visitors, read for admin ───────────────────────────
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /mentorship_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
